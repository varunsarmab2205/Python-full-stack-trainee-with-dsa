class Person:
    def __init__(self, name):
        self.name = name

    def show(self):
        print("Name:", self.name)

class Student(Person):
    def __init__(self, name, roll):
        super().__init__(name)
        self.roll = roll

    def details(self):
        print("Roll:", self.roll)

s1 = Student("Varun", 22)
s1.show()
s1.details()
